# Per-repo release config, consumed by .github/workflows/release.yml
# and scripts/render-formula.py. Keep values unquoted (loaded via GITHUB_ENV).
BIN_NAME=gitatlas
FORMULA_NAME=gitatlas-cli
FORMULA_CLASS=GitatlasCli
FORMULA_LICENSE=MIT
FORMULA_DESC=Multi-repo Git management CLI (companion to the gitatlas GUI)
